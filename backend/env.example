# LLM Provider Configuration (可选)
# 注意：这些环境变量现在是可选的！
# 你可以完全通过网页界面的"模型设置"来配置和使用模型，无需设置这些环境变量。
# 如果你想设置默认模型，可以取消注释下面的配置。
# Supported providers: gemini, openai, deepseek, kimi, qwen

# For Gemini (Recommended - Free tier available)
# LLM_PROVIDER=gemini
# LLM_API_KEY=your_gemini_api_key_here
# MODEL_NAME=gemini-1.5-flash  # 默认使用 gemini-1.5-flash (快速、便宜)
# MODEL_NAME=gemini-1.5-pro    # 或使用 gemini-1.5-pro (更强大)
# Get free API key at: https://aistudio.google.com/apikey

# For OpenAI
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# MODEL_NAME=gpt-3.5-turbo

# For DeepSeek (推荐使用，性价比高)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-your_deepseek_api_key_here
# MODEL_NAME=deepseek-chat
# Get API key at: https://platform.deepseek.com

# For Kimi (Moonshot)
# LLM_PROVIDER=kimi
# LLM_API_KEY=your_kimi_api_key_here
# MODEL_NAME=moonshot-v1-8k

# For Qwen
# LLM_PROVIDER=qwen
# LLM_API_KEY=your_qwen_api_key_here
# MODEL_NAME=qwen-turbo
